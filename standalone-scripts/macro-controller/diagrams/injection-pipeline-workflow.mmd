graph TD
    classDef userAction fill:#3B82F6,color:#fff,stroke:#2563EB,stroke-width:2px
    classDef stage fill:#8B5CF6,color:#fff,stroke:#7C3AED,stroke-width:2px
    classDef parallel fill:#EC4899,color:#fff,stroke:#DB2777,stroke-width:2px
    classDef process fill:#10B981,color:#fff,stroke:#059669,stroke-width:2px
    classDef decision fill:#F59E0B,color:#000,stroke:#D97706,stroke-width:2px
    classDef output fill:#EF4444,color:#fff,stroke:#DC2626,stroke-width:2px
    classDef fallback fill:#F97316,color:#fff,stroke:#EA580C,stroke-width:2px
    classDef logNode fill:#06B6D4,color:#fff,stroke:#0891B2,stroke-width:2px
    classDef errorNode fill:#DC2626,color:#fff,stroke:#B91C1C,stroke-width:2px
    classDef note fill:#334155,color:#CBD5E1,stroke:#475569,stroke-width:1px
    classDef cache fill:#14B8A6,color:#fff,stroke:#0D9488,stroke-width:2px

    A["User clicks Run Scripts in popup"]:::userAction
    A --> B["handleInjectScripts -- Pipeline Orchestrator"]:::stage
    B -. "1. Record performance.now start<br/>2. Query active tab via chrome.tabs<br/>3. Log INFO: pipeline START tabId, url, scriptCount" .-> BNOTE["Orchestrator entry point.<br/>All stages sequential except<br/>where marked parallel."]:::note

    B --> TOAST["Inject loading spinner toast into tab<br/>Fixed overlay: spinner + Injecting scripts..."]:::process
    TOAST -. "Visible during entire pipeline.<br/>Replaced by result toast at end." .-> TOASTNOTE["User sees immediate feedback<br/>that injection has started."]:::note

    %% ===== CACHE GATE =====
    TOAST --> CACHEVER["Read current version from manifest"]:::cache
    CACHEVER --> CACHE{"Cache Decision Gate<br/>IndexedDB: marco_injection_cache<br/>Lookup by version key"}:::cache
    CACHE -. "Key = manifest version string only.<br/>No hashing. No content comparison.<br/>Single entry for entire payload." .-> CACHENOTE["Version source:<br/>chrome.runtime.getManifest().version<br/>Same as EXTENSION_VERSION constant."]:::note

    CACHE -- "HIT: version matches<br/>LOG: cache HIT version=X.Y.Z" --> CACHEFAST["Skip Stages 0-3<br/>Use cached wrapped payload"]:::cache
    CACHEFAST --> EXEC

    CACHE -- "MISS: version mismatch<br/>LOG: cached=A.B.C current=X.Y.Z" --> GUARD
    CACHE -- "MISS: cache empty or removed<br/>LOG: no cached payload found" --> GUARD
    CACHE -- "CORRUPT: payload unreadable<br/>LOG ERROR: corrupt, delete + rebuild" --> GUARD

    %% ===== STAGE 0a =====
    GUARD["Stage 0a: ensureBuiltinScriptsExist"]:::stage
    GUARD -. "1. Read required built-in script IDs from manifest<br/>2. Check each exists in chrome.storage.local<br/>3. LOG INFO per found script<br/>4. LOG ERROR per missing script" .-> GUARDNOTE["Built-in scripts: SDK preamble,<br/>relay installer, namespace bootstrap.<br/>Self-heal missing from bundled /scripts/."]:::note
    GUARD --> GUARDFAIL{"Any built-in still missing<br/>after self-heal?"}:::decision
    GUARDFAIL -- "Yes" --> GUARDERR["HARD ERROR for that script.<br/>LOG ERROR. Continue with remaining."]:::errorNode
    GUARDFAIL -- "No" --> DEPS
    GUARDERR --> DEPS

    %% ===== STAGE 0b =====
    DEPS["Stage 0b: prependDependencyScripts"]:::stage
    DEPS -. "1. Read dependsOn from project config<br/>2. Build DAG, topological sort<br/>3. Prepend deps before dependents<br/>4. LOG INFO: resolved order" .-> DEPSNOTE["Example: if B depends on A,<br/>order becomes A, B, ...<br/>Missing dep = ERROR for both."]:::note
    DEPS --> DEPSFAIL{"Any dependency missing?"}:::decision
    DEPSFAIL -- "Yes" --> DEPSERR["ERROR: dep missing.<br/>Dependent also marked failed."]:::errorNode
    DEPSFAIL -- "No" --> RESOLVE
    DEPSERR --> RESOLVE

    %% ===== STAGE 1 =====
    RESOLVE["Stage 1: resolveInjectionRequestScripts"]:::stage
    RESOLVE -. "1. Load code from chrome.storage.local<br/>2. Load config JSON + theme JSON if bound<br/>3. Unresolvable = HARD ERROR, not skip<br/>4. LOG ERROR per failed script with reason" .-> RESOLVENOTE["Reasons: code_not_found,<br/>config_missing, type_mismatch.<br/>Zero resolved = pipeline halts."]:::note

    RESOLVE --> EMPTY{"Any scripts resolved?"}:::decision
    EMPTY -- "No" --> EARLYERR["Pipeline halts. Error toast:<br/>No scripts could be resolved.<br/>LOG ERROR."]:::errorNode
    EARLYERR --> TOASTFINAL
    EMPTY -- "Yes" --> PARALLEL1

    %% ===== STAGE 2 =====
    PARALLEL1["Stage 2: Tab Environment Prep -- Promise.all"]:::parallel

    PARALLEL1 --> P1A["2a: bootstrapNamespaceRoot"]:::process
    P1A -. "Create window.RiseupAsiaMacroExt in MAIN world.<br/>MAIN world = page JS context, shares window.<br/>If CSP blocks: health=DEGRADED, LOG ERROR.<br/>No ISOLATED fallback -- would be invisible to page." .-> P1ANOTE["Root namespace MUST exist<br/>before any script runs."]:::note

    PARALLEL1 --> P1B["2b: ensureRelayInjected"]:::process
    P1B -. "Relay = content script in ISOLATED world.<br/>It bridges page postMessage to chrome.runtime.<br/>Duplicate check: look for __marcoRelayInstalled marker.<br/>If marker exists = skip. If not = inject." .-> P1BNOTE["ISOLATED world: separate JS env.<br/>Shares DOM but not window vars.<br/>Relay uses postMessage as bridge."]:::note

    PARALLEL1 --> P1C["2c: seedTokensIntoTab"]:::process
    P1C -. "1. Read marco_bearer_token + timestamp from storage<br/>2. If age under TTL 2min: use stored token<br/>3. If expired: read cookie again, store with new timestamp<br/>4. Write token to tab localStorage via MAIN world<br/>NO auth logic, NO JWT validation, NO waterfall" .-> P1CNOTE["Simple flow: read cookie,<br/>store with timestamp,<br/>check expiry, re-read if stale."]:::note

    P1A --> BOOTDONE
    P1B --> BOOTDONE
    P1C --> BOOTDONE
    BOOTDONE["All 3 prep tasks complete"]:::process

    %% ===== STAGE 3 =====
    BOOTDONE --> INJECTCHECK{"Any scripts have CSS assets?"}:::decision

    INJECTCHECK -- "Yes: CSS detected" --> SEQ["Sequential Injection Mode"]:::fallback
    SEQ -. "CSS must load BEFORE its JS runs.<br/>Each script injected individually.<br/>LOG INFO: CSS detected, sequential mode." .-> SEQNOTE["CSS-first ensures styles are<br/>available when script creates UI."]:::note
    SEQ --> CSSINJECT["For each script with CSS:<br/>1. chrome.scripting.insertCSS -- inject stylesheet<br/>2. Wait for CSS load<br/>3. Wrap JS with try-catch IIFE<br/>4. Execute wrapped JS"]:::process
    CSSINJECT -. "LOG INFO: CSS injected path for scriptId<br/>LOG INFO: JS executed for scriptId" .-> CSSNOTE["If script has no CSS,<br/>inject its JS in same order<br/>but skip CSS step."]:::note
    CSSINJECT --> RESULTS

    INJECTCHECK -- "No CSS" --> BATCH["Stage 3: Batch Mode"]:::stage
    BATCH -. "Why batch? One chrome.scripting.executeScript<br/>call instead of N separate calls. Reduces<br/>round-trips between background and tab." .-> BATCHNOTE["Only used when no scripts<br/>need CSS assets."]:::note
    BATCH --> WRAP["Wrap each script in try-catch IIFE"]:::process
    WRAP -. "Each script gets:<br/>1. Own function scope -- no var leaks<br/>2. try-catch -- one failure wont break others<br/>3. SDK preamble -- marco helper access<br/>4. Error reporting via postMessage" .-> WRAPNOTE["Before: raw code.<br/>After: IIFE + try + code + catch + report"]:::note
    WRAP --> COMBINE["Join all wrapped IIFEs into one string:<br/>IIFE1 + newline + IIFE2 + newline + IIFE3<br/>Single string passed to Stage 4"]:::process
    COMBINE -. "LOG INFO: Combined payload size N bytes<br/>LOG INFO: N scripts prepared" .-> COMBINENOTE["One string = one executeScript call<br/>= one IPC round-trip to tab"]:::note

    COMBINE --> STORECACHE["Store payload in IndexedDB<br/>key = version string, no hashing"]:::cache
    STORECACHE -. "LOG: Stored payload for version=X.Y.Z, size=N bytes<br/>Cache cleared automatically by 3 layers:" .-> STORENOTE["Layer 1: chrome.runtime.onInstalled clears cache<br/>Layer 2: Version key mismatch auto-rebuilds<br/>Layer 3: PowerShell run.ps1 as safety net"]:::note
    STORECACHE --> EXEC

    %% ===== STAGE 4 =====
    EXEC["Stage 4: Execute in Tab"]:::stage
    EXEC -. "CSP = Content Security Policy.<br/>Example HTTP header from website:<br/>Content-Security-Policy: script-src self cdn.example.com<br/>Meaning: only run scripts from those sources.<br/>Our injected code is not from those sources." .-> CSPNOTE["Extension must use methods<br/>that work around CSP.<br/>Blob URLs bypass most CSP."]:::note

    EXEC --> BLOB["Primary: MAIN World Blob Injection"]:::process
    BLOB -. "1. Code string to Blob type=text/javascript<br/>2. URL.createObjectURL gives blob: URL<br/>3. Create script tag, src=blob URL<br/>4. Append to document.documentElement<br/>5. Browser executes in MAIN world<br/>6. Revoke blob URL after execution" .-> BLOBNOTE["MAIN world = page JS context.<br/>Full access to window, DOM, page globals.<br/>Blob URLs treated as same-origin by browser."]:::note

    BLOB --> UIINJECT["UI Injection Flow:<br/>Script runs in page context.<br/>MacroController class initializes.<br/>Creates UI container in DOM.<br/>UI becomes visible to user."]:::process
    UIINJECT -. "The script tag is in the real page DOM.<br/>Executed code has full page access.<br/>LOG INFO: Script executed in MAIN world." .-> UINOTE["This is how the macro UI<br/>appears in the users page."]:::note

    UIINJECT --> BLOBCHECK{"Blob injection succeeded?"}:::decision
    BLOBCHECK -- "Yes" --> RESULTS
    BLOBCHECK -- "No: CSP blocked blob URL" --> ISO

    ISO["Fallback: ISOLATED World -- LAST RESORT"]:::fallback
    ISO -. "ISOLATED world = separate JS environment.<br/>Has its own window object.<br/>Cannot see RiseupAsiaMacroExt or page vars.<br/>Can still manipulate DOM elements.<br/>Most macro features will NOT work." .-> ISONOTE["LOG ERROR: Forced to ISOLATED world.<br/>Health = DEGRADED.<br/>This is explicit degraded mode."]:::note
    ISO --> RESULTS

    %% ===== RESULTS =====
    RESULTS["Collect InjectionResult per script:<br/>scriptId, success, durationMs,<br/>injectionPath used, error if any"]:::stage

    %% ===== STAGE 5 =====
    RESULTS --> NS["Stage 5: Populate Data Namespaces -- Parallel"]:::parallel
    NS -. "Root object RiseupAsiaMacroExt exists from Stage 2a.<br/>Stage 5 fills it with runtime DATA:<br/>settings values and project variables." .-> NSNOTE["Scripts access data lazily via<br/>marco.whenReady or on user interaction,<br/>not synchronously at load time."]:::note

    NS --> NS_SET["5a: Settings + llmGuide<br/>RiseupAsiaMacroExt.Settings = values"]:::process
    NS --> NS_PROJ["5b: Projects per CodeName<br/>RiseupAsiaMacroExt.Projects.X = vars"]:::process
    NS_SET -. "LOG INFO: Settings populated N keys" .-> NSSETNOTE["If CSP blocks: DEGRADED + ERROR"]:::note
    NS_PROJ -. "LOG INFO: Projects populated: A, B" .-> NSPROJNOTE["Each project gets a vars Map<br/>for console variable access."]:::note

    NS_SET --> POST
    NS_PROJ --> POST

    %% ===== POST PIPELINE =====
    POST["Post-Pipeline Processing"]:::stage

    POST --> MIRROR["Mirror all pipeline logs to:<br/>1. Tab DevTools via console.groupCollapsed<br/>2. Extension SQLite via recordInjection<br/>3. OPFS session log"]:::logNode

    POST --> BUDGET{"Total time exceeds 2000ms?"}:::decision
    BUDGET -- "Yes" --> BUDGETWARN["LOG WARN: PERFORMANCE BUDGET EXCEEDED"]:::logNode
    BUDGET -- "No" --> VERIFY
    BUDGETWARN --> VERIFY

    VERIFY["Verify 6 post-injection globals"]:::stage
    VERIFY -. "1. window.marco -- SDK helper<br/>2. window.RiseupAsiaMacroExt -- root namespace<br/>3. window.MacroController -- controller class<br/>4. api.mc -- controller instance<br/>5. UI container in DOM<br/>6. __macroExtInjected flag" .-> VERIFYNOTE["LOG WARN for each failed check.<br/>Results saved to state manager."]:::note

    VERIFY --> TOASTFINAL{"Determine final toast"}:::decision
    TOASTFINAL -- "All pass" --> TSUCCESS["SUCCESS toast green:<br/>N scripts injected successfully"]:::process
    TOASTFINAL -- "Warnings" --> TWARN["WARNING toast amber:<br/>N injected, M warnings"]:::fallback
    TOASTFINAL -- "Failure" --> TERROR["ERROR toast red:<br/>Injection failed: reason"]:::errorNode

    TSUCCESS --> DONE
    TWARN --> DONE
    TERROR --> DONE
    DONE["Return InjectionResult array to popup"]:::userAction
